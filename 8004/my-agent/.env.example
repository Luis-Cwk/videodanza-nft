# ============================================
# LLM Configuration
# ============================================
# Opciones: ollama | openrouter | openai
# Para Railway: usa openrouter (no puedes correr Ollama ahi)
LLM_PROVIDER=openrouter
LLM_MODEL=qwen/qwen-2.5-coder-32b-instruct

# OpenRouter API Key (gratis/barato)
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ============================================
# Blockchain Configuration
# ============================================
PRIVATE_KEY=0x...
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
PINATA_JWT=eyJ...

# ============================================
# Agent Endpoints (se actualizan post-deploy)
# ============================================
# Railway asigna URL automaticamente, ejemplo:
# https://entropiav2-production.up.railway.app
A2A_ENDPOINT=https://TU-URL-DE-RAILWAY/.well-known/agent-card.json
MCP_ENDPOINT=https://TU-URL-DE-RAILWAY/mcp

# ============================================
# Server
# ============================================
PORT=3000
